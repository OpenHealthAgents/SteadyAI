# Public base URL used by client components in browser requests.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Supabase browser auth for Google / Apple SSO.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional server-side base URL override for server components/actions.
STEADY_API_BASE_URL=http://localhost:3000
